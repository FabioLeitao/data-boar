terraform {
  required_version = ">= 1.6.0"

  required_providers {
    docker = {
      source  = "kreuzwerker/docker"
      version = "~> 3.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.4"
    }
  }
}

# Docker provider connects to the Docker daemon on the target host.
# For remote hosts, set DOCKER_HOST env var or configure SSH tunnel.
provider "docker" {}