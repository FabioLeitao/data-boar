###############################################################################
# snmpd.conf — LAB-OP baseline (v3-only, opt-in)
#
# Policy:
# - v1/v2c are NOT configured.
# - Credentials MUST come from private inventory/vars (never tracked).
###############################################################################

agentAddress {{ lab-node-01_snmpd_agent_address }}

sysLocation {{ lab-node-01_snmpd_syslocation }}
sysContact {{ lab-node-01_snmpd_syscontact }}

# Do not expose dangerous write access; keep read-only views.
view   all    included  .1                               80
access v3grp  ""        any       authPriv   exact  all  none  none

{% for u in lab-node-01_snmpd_v3_users %}
# User: {{ u.username }} (level={{ u.level | default('authPriv') }})
{% if (u.level | default('authPriv')) == 'authPriv' %}
createUser {{ u.username }} {{ u.authproto | default('SHA') }} {{ u.authpass }} {{ u.privproto | default('AES') }} {{ u.privpass }}
{% else %}
createUser {{ u.username }} {{ u.authproto | default('SHA') }} {{ u.authpass }}
{% endif %}
rouser {{ u.username }} {{ u.level | default('authPriv') }}
{% endfor %}

